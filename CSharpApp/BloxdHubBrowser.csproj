<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>BloxdHubBrowser</RootNamespace>
    <AssemblyName>BloxdHub</AssemblyName>
    <StartupObject>BloxdHubBrowser.Program</StartupObject>
    <Product>BloxdHub Browser</Product>
    <Version>1.0.0</Version>
    <Authors>BloxdHub</Authors>
    <Description>A lightweight, modern browser with search integration</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2357.43" />
  </ItemGroup>

  <ItemGroup>
    <None Update="index.html" CopyToOutputDirectory="PreserveNewest" />
    <None Update="browser.js" CopyToOutputDirectory="PreserveNewest" />
    <None Update="style.css" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
