# BloxdHub Deployment Environment Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!

# SFTP Server Configuration
SFTP_HOST=bloxdhub-brower.cfd
SFTP_PORT=22
SFTP_USERNAME=elijah@bloxdhub-brower.cfd
SFTP_PASSWORD=your_secure_password_here
SFTP_REMOTE_PATH=/home/elijah/public_html/bloxdhub/

# FTP Server Configuration (if using FTP instead)
FTP_HOST=ftp.example.com
FTP_PORT=21
FTP_USERNAME=username
FTP_PASSWORD=your_password_here
FTP_REMOTE_PATH=/public_html/bloxdhub/

# Web Server Configuration
WEB_URL=https://bloxdhub-brower.cfd/downloads/BloxdHub.exe
WEB_ROOT=/home/elijah/public_html/

# Deployment Settings
DEPLOY_METHOD=sftp
CREATE_BACKUP=true
BACKUP_DIR=/home/elijah/backups/bloxdhub/
ENABLE_VERSION_TRACKING=true

# Notification Settings (optional)
NOTIFY_EMAIL=elijah@example.com
SLACK_WEBHOOK=
DISCORD_WEBHOOK=

# Build Settings
BUILD_ON_DEPLOY=false
RUN_TESTS=false
COMPRESS_FILES=true

# Security Settings
USE_SSH_KEY=false
SSH_KEY_PATH=~/.ssh/bloxdhub_rsa
SSH_KEY_PASSPHRASE=
